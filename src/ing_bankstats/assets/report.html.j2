<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Bank Statement Analysis</title>
  <script>{{ plotly_js }}</script>
  <style>
    :root {
      --bg:      #0f1117;
      --surface: #1c1e26;
      --border:  #2d3142;
      --text:    #e0e0e0;
      --muted:   #8892a4;
      --accent:  #4a9eff;
      --green:   #2ecc71;
      --red:     #e74c3c;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      background: var(--bg);
      color: var(--text);
      padding: 2rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .subtitle {
      color: var(--muted);
      margin-top: 0.35rem;
      margin-bottom: 2rem;
      font-size: 0.875rem;
    }

    /* ── Stats grid ──────────────────────────────────────────────────── */
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1.25rem 1.5rem;
    }

    .stat-label {
      color: var(--muted);
      font-size: 0.7rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      font-weight: 600;
    }

    .stat-value {
      font-size: 1.45rem;
      font-weight: 700;
      margin-top: 0.3rem;
      font-variant-numeric: tabular-nums;
    }

    .stat-value.green { color: var(--green); }
    .stat-value.red   { color: var(--red);   }
    .stat-value.dim   { color: var(--muted); }

    /* ── Chart containers ────────────────────────────────────────────── */
    .chart-full {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
      margin-bottom: 1rem;
    }

    .chart-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
      margin-bottom: 1rem;
    }

    .chart-half {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 1rem;
    }

    /* ── Uncategorised table ─────────────────────────────────────────── */
    details {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 0.75rem 1.25rem 1.25rem;
      margin-top: 0.5rem;
    }

    summary {
      cursor: pointer;
      font-weight: 600;
      color: var(--accent);
      user-select: none;
      padding: 0.4rem 0;
      font-size: 0.925rem;
    }

    summary::marker { color: var(--muted); }

    .hint {
      color: var(--muted);
      font-size: 0.8rem;
      margin: 0.5rem 0 1rem;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.85rem;
    }

    th {
      text-align: left;
      padding: 0.5rem 0.75rem;
      border-bottom: 2px solid var(--border);
      color: var(--muted);
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.7rem;
      letter-spacing: 0.06em;
    }

    td {
      padding: 0.45rem 0.75rem;
      border-bottom: 1px solid var(--border);
      vertical-align: middle;
    }

    tr:last-child td { border-bottom: none; }

    td.amount {
      text-align: right;
      font-family: ui-monospace, "SF Mono", monospace;
      white-space: nowrap;
    }

    td.amount.neg { color: var(--red); }

    td.merchant { font-weight: 500; }

    td.reference {
      color: var(--muted);
      font-size: 0.8rem;
      max-width: 420px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }

    @media (max-width: 900px) {
      .chart-row { grid-template-columns: 1fr; }
    }

    @media (max-width: 600px) {
      body { padding: 1rem; }
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
      h1 { font-size: 1.3rem; }
    }
  </style>
</head>
<body>

  <h1>Bank Statement Analysis</h1>
  <p class="subtitle">
    {{ stats.date_from }} – {{ stats.date_to }}
    &nbsp;·&nbsp; {{ stats.months_count }} month{% if stats.months_count != 1 %}s{% endif %}
    &nbsp;·&nbsp; {{ stats.transaction_count }} transactions
  </p>

  <div class="stats-grid">
    <div class="stat-card">
      <div class="stat-label">Total Income</div>
      <div class="stat-value green">{{ stats.total_income_fmt }}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Total Expenses</div>
      <div class="stat-value red">{{ stats.total_expenses_fmt }}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Net Savings</div>
      <div class="stat-value {{ 'green' if stats.net >= 0 else 'red' }}">{{ stats.net_fmt }}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Avg Monthly Income</div>
      <div class="stat-value">{{ stats.avg_monthly_income_fmt }}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Avg Monthly Expenses</div>
      <div class="stat-value">{{ stats.avg_monthly_expenses_fmt }}</div>
    </div>
    <div class="stat-card">
      <div class="stat-label">Uncategorised</div>
      <div class="stat-value dim">{{ stats.uncategorised_count }}</div>
    </div>
  </div>

  <div class="chart-full">{{ chart_income_expenses }}</div>
  <div class="chart-full">{{ chart_spending_by_category }}</div>

  <div class="chart-row">
    <div class="chart-half">{{ chart_category_pie }}</div>
    <div class="chart-half">{{ chart_savings }}</div>
  </div>

  {% if other_transactions %}
  <details>
    <summary>Uncategorised Transactions ({{ stats.uncategorised_count }})</summary>
    <p class="hint">
      Add keywords from the Merchant or Reference columns to your
      <code>categories.yaml</code> to categorise these automatically.
    </p>
    <table>
      <thead>
        <tr>
          <th>Date</th>
          <th>Merchant</th>
          <th>Reference</th>
          <th style="text-align:right">Amount</th>
        </tr>
      </thead>
      <tbody>
        {% for row in other_transactions %}
        <tr>
          <td>{{ row.date }}</td>
          <td class="merchant">{{ row.merchant }}</td>
          <td class="reference" title="{{ row.reference }}">{{ row.reference }}</td>
          <td class="amount {% if row.negative %}neg{% endif %}">
            {% if row.negative %}-{% endif %}{{ row.amount }}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </details>
  {% endif %}

</body>
</html>
